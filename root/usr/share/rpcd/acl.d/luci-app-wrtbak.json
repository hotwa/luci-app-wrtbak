{
	"luci-app-wrtbak": {
		"description": "Grant access to LuCI wrtbak",
		"read": {
			"cgi-io": [
				"download"
			],
			"file": {
				"/tmp/wrtbak/downloads/*.wrtbak": [
					"read",
					"stat"
				],
				"/tmp/wrtbak/downloads/*.sysupgrade.tar.gz": [
					"read",
					"stat"
				],
				"/tmp/wrtbak/restore-cache/*": [
					"read",
					"stat"
				],
				"/usr/bin/wrtbak detect --json": [
					"exec"
				],
				"/usr/bin/wrtbak info": [
					"exec"
				],
				"/usr/bin/wrtbak remote-status --json": [
					"exec"
				],
				"/usr/bin/wrtbak schedule-status --json": [
					"exec"
				],
				"/usr/bin/wrtbak remote-list *": [
					"exec"
				],
				"/usr/bin/wrtbak remote-download *": [
					"exec"
				],
				"/usr/bin/wrtbak restore-prepare *": [
					"exec"
				]
			},
			"ubus": {
				"file": [
					"exec",
					"read",
					"stat"
				],
				"session": [
					"access"
				],
				"uci": [
					"get",
					"state"
				]
			},
			"uci": [
				"wrtbak"
			]
		},
		"write": {
			"file": {
				"/usr/bin/wrtbak create-download *": [
					"exec"
				],
				"/usr/bin/wrtbak remote-test *": [
					"exec"
				],
				"/usr/bin/wrtbak remote-upload *": [
					"exec"
				],
				"/usr/bin/wrtbak remote-delete *": [
					"exec"
				],
				"/usr/bin/wrtbak remote-prune *": [
					"exec"
				],
				"/usr/bin/wrtbak restore-prebackup *": [
					"exec"
				],
				"/usr/bin/wrtbak restore-apply *": [
					"exec"
				],
				"/usr/bin/wrtbak restore-sysupgrade *": [
					"exec"
				],
				"/usr/bin/wrtbak schedule-apply --json": [
					"exec"
				]
			},
			"ubus": {
				"file": [
					"exec"
				],
				"uci": [
					"add",
					"apply",
					"confirm",
					"delete",
					"order",
					"set"
				]
			},
			"uci": [
				"wrtbak"
			]
		}
	}
}
