	wrtbak_target=
	wrtbak_path=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--target)
				[ "$#" -ge 2 ] || wrtbak_die "--target requires a value"
				wrtbak_target=$2
				shift 2
				;;
			--path)
				[ "$#" -ge 2 ] || wrtbak_die "--path requires a value"
				wrtbak_path=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown remote-download argument: $1"
