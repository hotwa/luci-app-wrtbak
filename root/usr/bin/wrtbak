	wrtbak_target=
	wrtbak_path=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--target)
				[ "$#" -ge 2 ] || wrtbak_die "--target requires a value"
				wrtbak_target=$2
				shift 2
				;;
			--path)
				[ "$#" -ge 2 ] || wrtbak_die "--path requires a value"
				wrtbak_path=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown remote-delete argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_target" ] || wrtbak_die "--target is required"
	[ -n "$wrtbak_path" ] || wrtbak_die "--path is required"
	wrtbak_remote_delete "$wrtbak_target" "$wrtbak_path"
}

wrtbak_parse_remote_prune() {
	wrtbak_target=
	wrtbak_max=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--target)
				[ "$#" -ge 2 ] || wrtbak_die "--target requires a value"
				wrtbak_target=$2
				shift 2
				;;
			--max)
				[ "$#" -ge 2 ] || wrtbak_die "--max requires a value"
				wrtbak_max=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown remote-prune argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_target" ] || wrtbak_die "--target is required"
	[ -n "$wrtbak_max" ] || wrtbak_die "--max is required"
	wrtbak_remote_prune "$wrtbak_target" "$wrtbak_max"
}

