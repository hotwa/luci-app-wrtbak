				wrtbak_die "unknown restore-prepare argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_input" ] || wrtbak_die "--input is required"
	wrtbak_restore_prepare "$wrtbak_input"
}

wrtbak_parse_restore_prebackup() {
	wrtbak_profile=
	wrtbak_items=
	wrtbak_format=wrtbak

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--profile)
				[ "$#" -ge 2 ] || wrtbak_die "--profile requires a value"
				wrtbak_profile=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			--format)
				[ "$#" -ge 2 ] || wrtbak_die "--format requires a value"
				wrtbak_format=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown restore-prebackup argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_profile" ] || wrtbak_die "--profile is required"
	[ -n "$wrtbak_items" ] || wrtbak_die "--items is required"
	wrtbak_restore_prebackup "$wrtbak_profile" "$wrtbak_items" "$wrtbak_format"
}

wrtbak_parse_restore_apply() {
	wrtbak_input=
	wrtbak_mode=selected
	wrtbak_items=all
	wrtbak_prebackup=
	wrtbak_confirm=
	wrtbak_restart_services=0

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--input)
				[ "$#" -ge 2 ] || wrtbak_die "--input requires a value"
				wrtbak_input=$2
				shift 2
				;;
			--mode)
				[ "$#" -ge 2 ] || wrtbak_die "--mode requires a value"
				wrtbak_mode=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			--prebackup)
				[ "$#" -ge 2 ] || wrtbak_die "--prebackup requires a value"
				wrtbak_prebackup=$2
				shift 2
				;;
			--confirm)
				[ "$#" -ge 2 ] || wrtbak_die "--confirm requires a value"
				wrtbak_confirm=$2
				shift 2
				;;
			--restart-services)
				[ "$#" -ge 2 ] || wrtbak_die "--restart-services requires a value"
				wrtbak_restart_services=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown restore-apply argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_input" ] || wrtbak_die "--input is required"
	[ -n "$wrtbak_prebackup" ] || wrtbak_die "--prebackup is required"
	[ -n "$wrtbak_confirm" ] || wrtbak_die "--confirm is required"
	wrtbak_restore_apply "$wrtbak_input" "$wrtbak_mode" "$wrtbak_items" "$wrtbak_prebackup" "$wrtbak_confirm" "$wrtbak_restart_services"
}

wrtbak_parse_restore_sysupgrade() {
	wrtbak_input=
	wrtbak_prebackup=
	wrtbak_confirm=
	wrtbak_execute=0

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--input)
				[ "$#" -ge 2 ] || wrtbak_die "--input requires a value"
				wrtbak_input=$2
				shift 2
				;;
			--prebackup)
				[ "$#" -ge 2 ] || wrtbak_die "--prebackup requires a value"
				wrtbak_prebackup=$2
				shift 2
				;;
			--confirm)
				[ "$#" -ge 2 ] || wrtbak_die "--confirm requires a value"
				wrtbak_confirm=$2
				shift 2
				;;
			--execute)
				[ "$#" -ge 2 ] || wrtbak_die "--execute requires a value"
				wrtbak_execute=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown restore-sysupgrade argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_input" ] || wrtbak_die "--input is required"
	[ -n "$wrtbak_prebackup" ] || wrtbak_die "--prebackup is required"
	[ -n "$wrtbak_confirm" ] || wrtbak_die "--confirm is required"
	wrtbak_restore_sysupgrade "$wrtbak_input" "$wrtbak_prebackup" "$wrtbak_confirm" "$wrtbak_execute"
}

wrtbak_parse_schedule_json_only() {
	wrtbak_schedule_command=$1
	shift
	while [ "$#" -gt 0 ]; do
		case "$1" in
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown $wrtbak_schedule_command argument: $1"
				;;
		esac
	done
	case "$wrtbak_schedule_command" in
		schedule-status)
			wrtbak_schedule_status_json
			;;
		schedule-apply)
			wrtbak_schedule_apply
			;;
	esac
}

wrtbak_parse_export_sysupgrade() {
	wrtbak_input=
	wrtbak_output=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--input)
				[ "$#" -ge 2 ] || wrtbak_die "--input requires a value"
				wrtbak_input=$2
				shift 2
				;;
			--output)
				[ "$#" -ge 2 ] || wrtbak_die "--output requires a value"
				wrtbak_output=$2
				shift 2
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown export-sysupgrade argument: $1"
				;;
		esac
	done

	wrtbak_export_sysupgrade "$wrtbak_input" "$wrtbak_output"
}

wrtbak_parse_create_download() {
	wrtbak_profile=
	wrtbak_items=
	wrtbak_format=wrtbak

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--profile)
				[ "$#" -ge 2 ] || wrtbak_die "--profile requires a value"
				wrtbak_profile=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			--format)
				[ "$#" -ge 2 ] || wrtbak_die "--format requires a value"
				wrtbak_format=$2
				shift 2
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown create-download argument: $1"
				;;
		esac
	done

	wrtbak_create_download "$wrtbak_profile" "$wrtbak_items" "$wrtbak_format"
}

wrtbak_parse_plan() {
	wrtbak_profile=
	wrtbak_items=
	wrtbak_format=wrtbak

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--profile)
				[ "$#" -ge 2 ] || wrtbak_die "--profile requires a value"
				wrtbak_profile=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			--format)
				[ "$#" -ge 2 ] || wrtbak_die "--format requires a value"
				wrtbak_format=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown plan argument: $1"
				;;
		esac
	done

	wrtbak_agent_plan_json "$wrtbak_profile" "$wrtbak_items" "$wrtbak_format"
}

wrtbak_parse_restore_plan() {
	wrtbak_input=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--input)
				[ "$#" -ge 2 ] || wrtbak_die "--input requires a value"
				wrtbak_input=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown restore-plan argument: $1"
				;;
		esac
	done

	wrtbak_agent_restore_plan_json "$wrtbak_input"
}

if [ "$#" -lt 1 ]; then
	wrtbak_usage >&2
	exit 1
fi

wrtbak_command=$1
shift

case "$wrtbak_command" in
	info)
		[ "$#" -eq 0 ] || wrtbak_die "info does not accept arguments"
		wrtbak_info
		;;
	identity)
		wrtbak_parse_identity "$@"
		;;
	status|doctor)
		wrtbak_parse_agent_json_only "$wrtbak_command" "$@"
		;;
	remote-status)
		wrtbak_parse_remote_status "$@"
		;;
	remote-test|remote-list)
		wrtbak_parse_remote_target_json_only "$wrtbak_command" "$@"
		;;
	remote-upload)
		wrtbak_parse_remote_upload "$@"
		;;
	remote-delete)
		wrtbak_parse_remote_delete "$@"
		;;
	remote-prune)
		wrtbak_parse_remote_prune "$@"
		;;
	remote-download)
		wrtbak_parse_remote_download "$@"
		;;
	restore-prepare)
		wrtbak_parse_restore_prepare "$@"
		;;
	restore-prebackup)
		wrtbak_parse_restore_prebackup "$@"
		;;
	restore-apply)
		wrtbak_parse_restore_apply "$@"
		;;
	restore-sysupgrade)
		wrtbak_parse_restore_sysupgrade "$@"
		;;
	schedule-status|schedule-apply)
		wrtbak_parse_schedule_json_only "$wrtbak_command" "$@"
		;;
	detect|list-items)
		wrtbak_parse_detect "$@"
		;;
	plan)
		wrtbak_parse_plan "$@"
		;;
	restore-plan)
		wrtbak_parse_restore_plan "$@"
		;;
	create)
		wrtbak_parse_create "$@"
		;;
	create-download)
		wrtbak_parse_create_download "$@"
		;;
	export-sysupgrade)
		wrtbak_parse_export_sysupgrade "$@"
		;;
	inspect)
		[ "$#" -eq 1 ] || wrtbak_die "inspect requires exactly one archive path"
		wrtbak_inspect_archive "$1"
		;;
	-h|--help|help)
		wrtbak_usage
		;;
	*)
		wrtbak_usage >&2
		wrtbak_die "unknown command: $wrtbak_command"
		;;
esac
