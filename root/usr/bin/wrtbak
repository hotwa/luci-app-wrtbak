#!/bin/sh
set -eu

: "${WRTBAK_LIBDIR:=/usr/lib/wrtbak}"

if [ ! -r "$WRTBAK_LIBDIR/common.sh" ]; then
	wrtbak_script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
	wrtbak_candidate=$(CDPATH= cd -- "$wrtbak_script_dir/../lib/wrtbak" 2>/dev/null && pwd || true)
	if [ -n "$wrtbak_candidate" ] && [ -r "$wrtbak_candidate/common.sh" ]; then
		WRTBAK_LIBDIR=$wrtbak_candidate
	fi
fi

[ -r "$WRTBAK_LIBDIR/common.sh" ] || {
	echo "wrtbak: cannot find common.sh in $WRTBAK_LIBDIR" >&2
	exit 1
}

. "$WRTBAK_LIBDIR/common.sh"
. "$WRTBAK_LIBDIR/manifest.sh"
. "$WRTBAK_LIBDIR/items.sh"
. "$WRTBAK_LIBDIR/backup.sh"
. "$WRTBAK_LIBDIR/pack.sh"
. "$WRTBAK_LIBDIR/web.sh"
. "$WRTBAK_LIBDIR/agent.sh"
. "$WRTBAK_LIBDIR/config.sh"
. "$WRTBAK_LIBDIR/identity.sh"
. "$WRTBAK_LIBDIR/remote.sh"
. "$WRTBAK_LIBDIR/remote_webdav.sh"
. "$WRTBAK_LIBDIR/remote_s3.sh"
. "$WRTBAK_LIBDIR/restore.sh"
. "$WRTBAK_LIBDIR/schedule.sh"

wrtbak_usage() {
	cat <<'EOF'
Usage:
  wrtbak info
  wrtbak identity --json
  wrtbak status --json
  wrtbak doctor --json
  wrtbak remote-status --json
  wrtbak remote-test --target webdav|s3 --json
  wrtbak remote-list --target default|webdav|s3 --json
  wrtbak remote-upload --target default|webdav|s3 --profile NAME --items IDS|all --format wrtbak|sysupgrade [--prune-max N] --json
  wrtbak remote-delete --target default|webdav|s3 --path REMOTE_PATH --json
  wrtbak remote-prune --target default|webdav|s3 --max N --json
  wrtbak remote-download --target default|webdav|s3 --path REMOTE_PATH --json
  wrtbak restore-prepare --input LOCAL_ARCHIVE --json
  wrtbak restore-prebackup --profile pre-restore --items all --format wrtbak --json
  wrtbak restore-apply --input LOCAL_ARCHIVE --mode all|selected --items IDS|all --prebackup LOCAL_ARCHIVE --confirm RESTORE [--restart-services 0|1] --json
  wrtbak restore-sysupgrade --input LOCAL_ARCHIVE --prebackup LOCAL_ARCHIVE --confirm RESTORE [--execute 0|1] --json
  wrtbak schedule-status --json
  wrtbak schedule-apply --json
  wrtbak detect [--json]
  wrtbak plan --profile NAME --items IDS --format wrtbak|sysupgrade --json
  wrtbak restore-plan --input FILE --json
  wrtbak create --profile NAME --output FILE [--items IDS]
  wrtbak create-download --profile NAME --items IDS --format wrtbak|sysupgrade
  wrtbak export-sysupgrade --input FILE --output FILE
  wrtbak inspect FILE
EOF
}

wrtbak_info() {
	printf 'luci-app-wrtbak %s\n' "$WRTBAK_VERSION"
	printf 'root: %s\n' "${WRTBAK_ROOT:-/}"
	printf 'libdir: %s\n' "$WRTBAK_LIBDIR"
	printf 'paths_file: %s\n' "$(wrtbak_paths_file)"
	printf 'format: wrtbak/v1\n'
}

wrtbak_parse_create() {
	wrtbak_profile=
	wrtbak_output=
	wrtbak_items=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--profile)
				[ "$#" -ge 2 ] || wrtbak_die "--profile requires a value"
				wrtbak_profile=$2
				shift 2
				;;
			--output)
				[ "$#" -ge 2 ] || wrtbak_die "--output requires a value"
				wrtbak_output=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown create argument: $1"
				;;
		esac
	done

	wrtbak_create_archive "$wrtbak_profile" "$wrtbak_output" "$wrtbak_items"
}

wrtbak_parse_detect() {
	while [ "$#" -gt 0 ]; do
		case "$1" in
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown detect argument: $1"
				;;
		esac
	done

	wrtbak_detect_items_json
}

wrtbak_parse_agent_json_only() {
	wrtbak_agent_command=$1
	shift

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown $wrtbak_agent_command argument: $1"
				;;
		esac
	done

	case "$wrtbak_agent_command" in
		status)
			wrtbak_agent_status_json
			;;
		doctor)
			wrtbak_agent_doctor_json
			;;
	esac
}

wrtbak_parse_remote_status() {
	while [ "$#" -gt 0 ]; do
		case "$1" in
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown remote-status argument: $1"
				;;
		esac
	done

	wrtbak_remote_status_json
}

wrtbak_parse_remote_target_json_only() {
	wrtbak_remote_command=$1
	shift
	wrtbak_target=

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--target)
				[ "$#" -ge 2 ] || wrtbak_die "--target requires a value"
				wrtbak_target=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown $wrtbak_remote_command argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_target" ] || wrtbak_die "--target is required"

	case "$wrtbak_remote_command" in
		remote-test)
			wrtbak_remote_test "$wrtbak_target"
			;;
		remote-list)
			wrtbak_remote_list "$wrtbak_target"
			;;
	esac
}

wrtbak_parse_remote_upload() {
	wrtbak_target=
	wrtbak_profile=
	wrtbak_items=
	wrtbak_format=wrtbak
	wrtbak_prune_max=0

	while [ "$#" -gt 0 ]; do
		case "$1" in
			--target)
				[ "$#" -ge 2 ] || wrtbak_die "--target requires a value"
				wrtbak_target=$2
				shift 2
				;;
			--profile)
				[ "$#" -ge 2 ] || wrtbak_die "--profile requires a value"
				wrtbak_profile=$2
				shift 2
				;;
			--items)
				[ "$#" -ge 2 ] || wrtbak_die "--items requires a value"
				wrtbak_items=$2
				shift 2
				;;
			--format)
				[ "$#" -ge 2 ] || wrtbak_die "--format requires a value"
				wrtbak_format=$2
				shift 2
				;;
			--prune-max)
				[ "$#" -ge 2 ] || wrtbak_die "--prune-max requires a value"
				wrtbak_prune_max=$2
				shift 2
				;;
			--json)
				shift
				;;
			-h|--help)
				wrtbak_usage
				exit 0
				;;
			*)
				wrtbak_die "unknown remote-upload argument: $1"
				;;
		esac
	done

	[ -n "$wrtbak_target" ] || wrtbak_die "--target is required"
	[ -n "$wrtbak_profile" ] || wrtbak_die "--profile is required"
	[ -n "$wrtbak_items" ] || wrtbak_die "--items is required"
	wrtbak_remote_upload "$wrtbak_target" "$wrtbak_profile" "$wrtbak_items" "$wrtbak_format" "$wrtbak_prune_max"
}

